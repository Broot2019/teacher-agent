graph TB
    subgraph 用户层["👥 用户层"]
        TEACHER["教师用户"]
        ADMIN["管理员"]
        BROWSER["浏览器"]
    end

    subgraph 前端层["🎨 前端层 (Vue 3)"]
        LP["教案生成"]
        QB["题库生成"]
        KB["知识库"]
        QA["智能答疑"]
        DASH["仪表盘"]
    end

    subgraph 后端层["⚙️ 后端层 (Spring Boot)"]
        CTRL["Controller"]
        SVC["Service"]
        LLM["LLM Client"]
        RAG["RAG Service"]
        SEC["Security"]
    end

    subgraph 数据层["💾 数据层"]
        MYSQL["MySQL"]
        FILES["知识库文件"]
        HIST["教案/题库历史"]
        USER["用户/权限"]
    end

    subgraph 外部服务["☁️ 外部服务"]
        DS["DeepSeek"]
        ZP["智谱清言"]
        QW["通义千问"]
        KIMI["Kimi"]
        MM["MiniMax"]
    end

    TEACHER --> BROWSER
    ADMIN --> BROWSER
    BROWSER --> LP & QB & KB & QA & DASH
    LP & QB & KB & QA & DASH --> CTRL
    CTRL --> SVC
    SVC --> LLM & RAG
    LLM & RAG --> DS & ZP & QW & KIMI & MM
    SVC --> MYSQL & FILES & HIST & USER
    SEC --> CTRL

    style 用户层 fill:#e3f2fd,stroke:#01579b,stroke-width:3px
    style 前端层 fill:#f3e5f5,stroke:#4a148c,stroke-width:3px
    style 后端层 fill:#fff3e0,stroke:#e65100,stroke-width:3px
    style 数据层 fill:#e8f5e9,stroke:#1b5e20,stroke-width:3px
    style 外部服务 fill:#fce4ec,stroke:#880e4f,stroke-width:3px

    classDef userStyle fill:#4fc3f7,stroke:#0277bd,stroke-width:2px,color:#000
    classDef frontendStyle fill:#7e57c2,stroke:#512da8,stroke-width:2px,color:#fff
    classDef backendStyle fill:#ffb74d,stroke:#ef6c00,stroke-width:2px,color:#000
    classDef dataStyle fill:#81c784,stroke:#388e3c,stroke-width:2px,color:#000
    classDef llmStyle fill:#ff8a65,stroke:#d84315,stroke-width:2px,color:#fff

    class TEACHER,ADMIN,BROWSER userStyle
    class LP,QB,KB,QA,DASH frontendStyle
    class CTRL,SVC,LLM,RAG,SEC backendStyle
    class MYSQL,FILES,HIST,USER dataStyle
    class DS,ZP,QW,KIMI,MM llmStyle
