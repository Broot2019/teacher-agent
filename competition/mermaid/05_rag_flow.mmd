flowchart TD
    subgraph 左侧["📚 知识库构建"]
        A1["📄 上传文档<br/>PDF/PPT/Word"]
        A2["🔤 文档解析<br/>PDFBox/poi-tl"]
        A3["✂️ 智能分块<br/>200-500字/块"]
        A4["🏷️ TF关键词<br/>自动提取"]
        A5["💾 索引存储<br/>关键词→文档块"]
    end

    subgraph 右侧["🔄 检索增强生成"]
        B1["👤 用户请求<br/>生成教案/题库"]
        B2["🔤 提取关键词<br/>TF-IDF"]
        B3["🔍 检索知识库<br/>关键词匹配"]
        B4["📖 获取相关片段<br/>Top-K"]
        B5["📝 构建提示词<br/>用户请求+知识库内容"]
        B6["🤖 调用LLM<br/>增强生成"]
        B7["📤 生成输出<br/>准确可靠"]
    end

    subgraph 底部["💡 方案优势"]
        C1["⚡ 轻量级<br/>无需向量数据库"]
        C2["🚀 部署简单<br/>适合高职院校"]
        C3["⏱️ 响应快速<br/>秒级检索"]
        C4["📖 可解释性强<br/>明确引用来源"]
    end

    A1 --> A2 --> A3 --> A4 --> A5

    B1 --> B2 --> B3
    B3 -.->|检索| A5
    A5 -.->|返回相关块| B4
    B4 --> B5 --> B6 --> B7

    B7 --> 底部

    style 左侧 fill:#e8f5e9,stroke:#2e7d32,stroke-width:3px
    style 右侧 fill:#fff3e0,stroke:#e65100,stroke-width:3px
    style 底部 fill:#e3f2fd,stroke:#1976d2,stroke-width:3px

    style A5 fill:#81c784,stroke:#388e3c,stroke-width:2px
    style B7 fill:#4361ee,stroke:#1a1a2e,stroke-width:2px,color:#fff

    classDef processNode fill:#fff,stroke:#555,stroke-width:1px
    class A1,A2,A3,A4,B1,B2,B3,B4,B5,B6 processNode

    classDef advantageNode fill:#4fc3f7,stroke:#0277bd,stroke-width:2px
    class C1,C2,C3,C4 advantageNode
