flowchart TD
    START(["📥 开始"])

    PHASE1(("📋 阶段1<br/>初次生成"))
    INPUT["用户上传素材<br/>PPT/PDF/Word"]
    PROMPT["构建提示词模板<br/>+ 课程配置"]
    LLM1["调用国产大模型<br/>DeepSeek/智谱/千问"]
    DRAFT["生成初稿"]

    CHECK1{🔍 合规检查}
    PASS_OK["✅ 格式规范<br/>✅ 思政要素<br/>✅ 知识点完整"]

    PHASE2(("🔧 阶段2<br/>合规自检"))
    SELF1["AI检查格式规范"]
    SELF2["AI检查思政要素"]
    SELF3["AI检查知识点"]

    CHECK2{⚖️ 二次判断}

    PHASE3(("🎯 阶段3<br/>AI批判与修正"))
    CRITIC1["AI角色扮演<br/>专业评审员"]
    CRITIC2["专业批判<br/>指出问题"]
    CRITIC3["修正重生成"]

    COMPILE["🔨 编译校验<br/>(题库专用)"]

    CHECK3{✨ 最终质检}
    OUTPUT(["📤 输出高质量资源<br/>Word/Excel"])

    FAIL["❌ 不通过<br/>返回重新生成"]

    STATS["📈 合格率提升<br/>60% → 90%+"]

    START --> PHASE1
    PHASE1 --> INPUT --> PROMPT --> LLM1 --> DRAFT
    DRAFT --> CHECK1

    CHECK1 -->|通过| PASS_OK --> PHASE2
    CHECK1 -->|不通过| FAIL --> PHASE1

    PHASE2 --> SELF1 & SELF2 & SELF3
    SELF1 & SELF2 & SELF3 --> CHECK2

    CHECK2 -->|通过| PHASE3
    CHECK2 -->|不通过| FAIL

    PHASE3 --> CRITIC1 --> CRITIC2 --> CRITIC3
    CRITIC3 --> CHECK3

    CHECK3 -->|不通过| CRITIC1
    CHECK3 -->|通过| COMPILE --> CHECK3

    CHECK3 -->|最终通过| OUTPUT --> STATS

    style START fill:#e3f2fd,stroke:#1976d2,stroke-width:2px
    style OUTPUT fill:#2e7d32,stroke:#1b5e20,stroke-width:2px,color:#fff
    style FAIL fill:#ffebee,stroke:#c62828,stroke-width:2px

    style PHASE1 fill:#4361ee,stroke:#1a1a2e,stroke-width:2px,color:#fff
    style PHASE2 fill:#f77f00,stroke:#1a1a2e,stroke-width:2px,color:#fff
    style PHASE3 fill:#7209b7,stroke:#1a1a2e,stroke-width:2px,color:#fff

    classDef processNode fill:#fff,stroke:#333,stroke-width:1px
    class INPUT,PROMPT,LLM1,DRAFT,SELF1,SELF2,SELF3,CRITIC1,CRITIC2,CRITIC3,COMPILE processNode

    classDef decisionNode fill:#fff9c4,stroke:#f57f17,stroke-width:2px
    class CHECK1,CHECK2,CHECK3 decisionNode
