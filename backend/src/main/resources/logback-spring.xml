<?xml version="1.0" encoding="UTF-8"?>
<!--
    Logback 配置：强制 ConsoleAppender 使用 UTF-8 编码输出，避免 Windows 控制台 codepage 936(GBK)
    解码 UTF-8 字节流时出现的 "鐢ㄦ埛鐧诲綍" 等乱码。
    同时把日志格式标准化（线程/级别/Logger/消息），便于排查。
-->
<configuration>

    <!-- 控制台输出，强制 UTF-8 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <charset>UTF-8</charset>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 文件输出（可选），同样 UTF-8 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/teacher-agent.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/teacher-agent.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>20MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <charset>UTF-8</charset>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{50} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 项目日志默认 INFO（应用代码） -->
    <logger name="com.teacheragent" level="INFO" />

    <!-- 第三方包静音常见噪音 -->
    <logger name="org.springframework.web.servlet.PageNotFound" level="WARN" />
    <logger name="org.springframework.web.servlet.resource" level="WARN" />
    <logger name="org.apache.ibatis" level="WARN" />
    <logger name="com.baomidou.mybatisplus" level="WARN" />

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>

</configuration>
